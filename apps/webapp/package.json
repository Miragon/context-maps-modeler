{
  "name": "@miragon/context-maps-webapp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Context Maps Modeler web application (Vite demo editor).",
  "scripts": {
    "dev": "PORTLESS_HTTPS=0 PORTLESS_PORT=8080 portless context-maps-modeler vite",
