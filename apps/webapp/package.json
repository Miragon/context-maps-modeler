    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.node.json"
  },
  "dependencies": {
    "@miragon/context-maps-cml": "0.0.1",
    "@miragon/context-maps-renderer": "0.0.1",
    "@miragon/context-maps-schema-model": "0.0.1",
    "lz-string": "1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "portless": "0.15.0",
    "vite": "8.1.0"
  }
}
